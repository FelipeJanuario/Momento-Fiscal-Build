<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      /* Reset some default styles */
      body, table, td, a {
        font-family: Roboto, Arial, sans-serif;
        font-size: 18px;
        line-height: 1.6;
        margin: 0;
        padding: 0;
      }

      p {
        margin: 0 0 10px;
      }

      a {
        color: #007bff;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      /* Center the card container */
      .card-container {
          text-align: center;
          width: 100%;
      }
      /* Style the card */
      .card {
          background-color: #fff;
          border-radius: 10px;
          box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
          display: inline-block; /* Make the card shrink to fit content */
          margin: 20px auto; /* Center horizontally with top/bottom margin */
          max-width: 600px; /* Limit card width */
          padding: 20px;
          text-align: left; /* Align card content to the left */
          width: 80%; /* Occupy 80% of container width */
      }
      /* Responsive image */
      .card img {
          display: block;
          max-width: 100%;
          height: auto;
      }
      /* Media query for smaller screens */
      @media (max-width: 480px) {
          .card {
              width: 95%; /* Occupy more space on smaller screens */
          }
      }
    </style>
  </head>

  <body>
    <div class="card-container">
      <div class="card">
        <%= render 'layouts/base64_logo' %>

        <%= yield %>
      </div>
    </div>
  </body>
</html>
