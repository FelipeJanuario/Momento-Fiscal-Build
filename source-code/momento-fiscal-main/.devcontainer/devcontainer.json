// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
  "name": "Momento Fiscal | Dev Container",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "initializeCommand": "ls",
  "dockerFile": "Dockerfile",
  "customizations": {
    "vscode": {
      "extensions": [
        // Ruby development VS Code extensions
        "Shopify.ruby-lsp",
        "wingrunr21.vscode-ruby",
        "bung87.vscode-gemfile",
        "rubocop.vscode-rubocop",
        "miguel-savignano.ruby-symbols",

        // Docker development VS Code extensions
        "dbaeumer.vscode-eslint",
        "ms-azuretools.vscode-docker",

        // Flutter development VS Code extensions
        "dart-code.flutter",
        "dart-code.dart-code"
      ],
      "settings": {
        "remote.localPortHost": "allInterfaces",
        "terminal.integrated.shell.linux": "/bin/bash",
        "editor.tabSize": 2,
        "editor.detectIndentation": false,
        "editor.insertSpaces": true,
        "[ruby]": {
          "editor.defaultFormatter": "rubocop.vscode-rubocop",
          "editor.formatOnSave": true
        }
      }
    }
  },
  "features": {
    "docker-in-docker": {
      "version": "latest"
    }
  },
  "mounts": [
    "source=${localWorkspaceFolder},target=/app,type=bind,consistency=consistent"
  ],
  "remoteEnv": {
    "RAILS_ENV": "development",
