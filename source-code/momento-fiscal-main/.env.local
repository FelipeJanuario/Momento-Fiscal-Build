# =============================================================================
# VARIÁVEIS DE AMBIENTE PARA TESTE LOCAL
# =============================================================================
# Copie para .env.local e ajuste conforme necessário
# Uso: docker-compose -f docker-compose.local.yml --env-file .env.local up
# =============================================================================

# Modo Desenvolvimento (true = CORS liberado, Stripe mock, Biddings mock)
DEV_MODE=true

# Rails Secret (gere um novo: openssl rand -hex 64)
