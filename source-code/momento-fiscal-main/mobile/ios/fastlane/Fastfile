default_platform(:ios)

# ──────────────────────────────────────────────────────────────────
#  Helper: carrega a API Key do App Store Connect via variáveis de
#  ambiente injetadas pelo GitHub Actions (secrets).
# ──────────────────────────────────────────────────────────────────
def load_asc_api_key
  app_store_connect_api_key(
    key_id:        ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id:     ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
    key_content:   ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
    is_key_content_base64: true,
    in_house: false
  )
end

# ──────────────────────────────────────────────────────────────────
#  Helper: localiza o IPA gerado pelo Flutter (nome pode variar
#  conforme CFBundleDisplayName / CFBundleName).
# ──────────────────────────────────────────────────────────────────
def find_ipa
  ipa_dir = File.expand_path("../../build/ios/ipa", __dir__)
  ipas = Dir.glob("#{ipa_dir}/*.ipa")
  UI.user_error!("Nenhum IPA encontrado em #{ipa_dir}") if ipas.empty?
  UI.message("📦 IPA encontrado: #{ipas.first}")
  ipas.first
end

platform :ios do

  # ── TestFlight ────────────────────────────────────────────────────
  desc "Faz upload do build para o TestFlight"
  lane :testflight_upload do
    api_key = load_asc_api_key

    upload_to_testflight(
      api_key:            api_key,
      ipa:                find_ipa,
      skip_waiting_for_build_processing: true,
      changelog:          "Build gerado automaticamente via GitHub Actions"
    )
  end

  # ── App Store ────────────────────────────────────────────────────
  desc "Faz upload e submete o build para revisão na App Store"
  lane :appstore_upload do
    api_key = load_asc_api_key

    deliver(
      api_key:             api_key,
      ipa:                 find_ipa,
      submit_for_review:   true,
      automatic_release:   false,
      force:               true,
      skip_screenshots:    true,
      skip_metadata:       true
    )
  end

end
