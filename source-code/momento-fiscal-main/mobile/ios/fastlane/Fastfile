default_platform(:ios)

# ──────────────────────────────────────────────────────────────────
#  Helper: carrega a API Key do App Store Connect via variáveis de
#  ambiente injetadas pelo GitHub Actions (secrets).
# ──────────────────────────────────────────────────────────────────
def load_asc_api_key
  app_store_connect_api_key(
    key_id:        ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id:     ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
    key_content:   ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
    is_key_content_base64: true,
    in_house: false
  )
end

platform :ios do

  # ── TestFlight ────────────────────────────────────────────────────
  # Disparado em tags *-rc* (release candidate) ou manualmente.
  # Envia o IPA para o TestFlight sem submetê-lo à revisão da Apple.
  desc "Faz upload do build para o TestFlight"
  lane :testflight do
    api_key = load_asc_api_key

    upload_to_testflight(
      api_key:            api_key,
      ipa:                "../build/ios/ipa/momentofiscal.ipa",
      skip_waiting_for_build_processing: true,
      changelog:          "Build gerado automaticamente via GitHub Actions"
    )
  end

  # ── App Store ────────────────────────────────────────────────────
  # Disparado em tags de versão (v*.*.*). Envia para revisão da Apple.
  desc "Faz upload e submete o build para revisão na App Store"
  lane :appstore do
    api_key = load_asc_api_key

    deliver(
      api_key:             api_key,
      ipa:                 "../build/ios/ipa/momentofiscal.ipa",
      submit_for_review:   true,
      automatic_release:   false,   # mude para true se quiser release automático após aprovação
      force:               true,    # não exige que metadados existam localmente
      skip_screenshots:    true,
      skip_metadata:       true
    )
  end

end
