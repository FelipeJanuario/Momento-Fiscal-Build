# =============================================================================
# ARQUIVO DE VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# =============================================================================
# Copie este arquivo para .env e preencha os valores
# Uso: cp .env.production.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# DOCKER & APLICAÇÃO
# -----------------------------------------------------------------------------
# Nome da imagem Docker (será buildada localmente)
APP_BACK_IMAGE=momento-fiscal-api:latest

# Domínio da aplicação (configure DNS apontando para o IP da VM)
APP_DOMAIN=api.momentofiscal.com.br

# Modo Desenvolvimento (true = CORS liberado, false = CORS restrito)
# IMPORTANTE: Em produção, sempre use DEV_MODE=false
DEV_MODE=false

# -----------------------------------------------------------------------------
# OPENTELEMETRY (Monitoramento)
# -----------------------------------------------------------------------------
# Nome do serviço para telemetria
OTEL_SERVICE_NAME=momento-fiscal-api

# Endpoint do coletor OpenTelemetry
# Se não tiver, pode usar: http://localhost:4318 (desabilitado)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# EMAIL (SMTP)
# -----------------------------------------------------------------------------
# Configurações do servidor SMTP para envio de emails
MAIL_SMTP_PORT=587
MAIL_SMTP_LOGIN=seu-email@gmail.com
MAIL_SMTP_DOMAIN=gmail.com
MAIL_SMTP_SSL=true

# A senha do SMTP está no Docker Secret: momento_fiscal_smtp_password
MAIL_SMTP_PASSWORD_FILE=/run/secrets/momento_fiscal_smtp_password

# -----------------------------------------------------------------------------
# CRIPTOGRAFIA (Active Record Encryption)
# -----------------------------------------------------------------------------
# Chaves de criptografia (usando Docker Secrets)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY_FILE=/run/secrets/momento_fiscal_active_record_encryption_primary_key
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY_FILE=/run/secrets/momento_fiscal_active_record_encryption_deterministic_key
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT_FILE=/run/secrets/momento_fiscal_active_record_encryption_key_derivation_salt

# -----------------------------------------------------------------------------
# BIDDINGS ANALYSER (API Externa)
# -----------------------------------------------------------------------------
# URL da API de análise de licitações
BIDDINGS_ANALYSER_URL=https://sua-api-biddings.com

# API Key (usando Docker Secret)
BIDDINGS_ANALYSER_API_KEY_FILE=/run/secrets/momento_fiscal_biddings_analyser_api_key

# -----------------------------------------------------------------------------
# STRIPE (Pagamentos)
# -----------------------------------------------------------------------------
# Chave secreta do Stripe (usando Docker Secret)
STRIPE_SECRET_KEY_FILE=/run/secrets/momento_fiscal_stripe_secret_key

# Chave pública do Stripe (pode ser pública)
STRIPE_PUBLISHABLE_KEY=pk_live_seu_publishable_key_aqui

# -----------------------------------------------------------------------------
# JUSBRASIL (Processos Judiciais)
# -----------------------------------------------------------------------------
# Token de API do JusBrasil
JUSBRASIL_API_TOKEN=seu_token_jusbrasil

# -----------------------------------------------------------------------------
# SERPRO (Consultas CPF/CNPJ)
# -----------------------------------------------------------------------------
# Credenciais da API do SERPRO
SERPRO_CONSUMER_KEY=sua_consumer_key
SERPRO_CONSUMER_SECRET=sua_consumer_secret

# -----------------------------------------------------------------------------
# PJE (Processos Judiciais Eletrônicos)
# -----------------------------------------------------------------------------
# Certificados PJE (usando Docker Secrets)
PJE_AUTH_PFX_FILE=/run/secrets/momento_fiscal_pje_auth_pfx
PJE_AUTH_PFX_PASSWORD_FILE=/run/secrets/momento_fiscal_pje_auth_pfx_password
PJE_AUTH_CERTCHAIN_FILE=/run/secrets/momento_fiscal_pje_auth_certchain

# -----------------------------------------------------------------------------
# GOOGLE PLAY (Billing)
# -----------------------------------------------------------------------------
# Certificado Google API em Base64 (usando Docker Secret)
GOOGLE_API_PFX_BASE64_FILE=/run/secrets/momento_fiscal_google_api_pfx_base64

# -----------------------------------------------------------------------------
# OBSERVAÇÕES
# -----------------------------------------------------------------------------
# 
# ⚠️  NUNCA commite o arquivo .env com valores reais!
# 
# 🔐 Secrets são gerenciados pelo Docker Swarm:
#    - PostgreSQL password
#    - Rails secret key base
#    - SMTP password
#    - Lockbox master key
#    - Active Record Encryption keys
#    - Stripe secret key
#    - Certificados PJE
#    - Google API PFX
# 
# Execute: bash infrastructure/scripts/create-secrets.sh para criar os secrets
# 
# 📝 Para valores sensíveis adicionais, prefira usar Docker Secrets:
#    echo "valor_secreto" | docker secret create nome_do_secret -
# 
